@startuml
skinparam classAttributeIconSize 0
title Academic Tracker - Main Class Diagram

package "com.tracker.academictracker.app" {
  class Launcher {
    +main(args: String[]): void
  }

  class Main {
    +start(stage: Stage): void
    +showWelcomeScreen(): void
    +showDashboard(student: Student): void
    +main(args: String[]): void
  }
}

package "com.tracker.academictracker.domain.model" {
  class Student {
    -fullName: String
    -studentId: String
    -semesters: List<Semester>
    -activeSemesterName: String
    +addSemester(semester: Semester): void
    +removeSemester(semester: Semester): void
    +getCumulativeGPA(): double
    +getCompletedGPA(): double
    +getTotalCreditsCompleted(): int
    +getAcademicStanding(): String
  }

  class Semester {
    -year: int
    -termType: String
    -courses: List<Course>
    +addCourse(course: Course): void
    +removeCourse(course: Course): void
    +getDisplayName(): String
    +getGPA(): double
    +getAverageScore(): double
  }

  class Course {
    -courseCode: String
    -courseName: String
    -credits: int
    -status: CourseStatus
    -assessments: List<Assessment>
    +addAssessment(assessment: Assessment): void
    +removeAssessment(assessment: Assessment): void
    +getTotalWeight(): double
    +isWeightTotalValid(): boolean
    +getCurrentGrade(): double
  }

  class Assessment {
    -assessmentName: String
    -category: String
    -weight: double
    -score: Double
    -maxScore: double
    +isGraded(): boolean
    +getWeightScore(): double
  }

  enum CourseStatus {
    ACTIVE
    COMPLETED
    DROPPED
    +getDisplayName(): String
  }
}

package "com.tracker.academictracker.persistence" {
  class DataManager {
    +saveStudent(student: Student): void
    +loadStudent(): Student
    +saveFileExists(): boolean
  }
}

package "com.tracker.academictracker.service" {
  class PredictionService {
    -mapper: PredictionMapper
    -facade: PredictionCoreFacade
    +calculateCourseGrade(course: Course): GradeResult
    +predictCourseTarget(course: Course, targetScore: double): CoursePredictionResult
    +projectStudentGpa(student: Student): GpaProjectionResult
    +projectSemesterGpa(semester: Semester): GpaProjectionResult
    +calculateRequiredActiveTermGpa(student: Student, activeSemester: Semester, targetGpa: double): TargetGpaResult
  }
}

package "com.tracker.academictracker.mapper" {
  class PredictionMapper {
    +toTranscriptInput(student: Student, remainingCredits: int): TranscriptInput
    +toSemesterInput(semester: Semester): SemesterInput
    +toCourseInput(course: Course): CourseInput
    +toAssessmentInput(assessment: Assessment): AssessmentInput
    +countActiveCredits(semester: Semester): int
  }
}

package "com.tracker.academictracker.ui.controller" {
  class DashboardController {
    -predictionService: PredictionService
    +initData(student: Student): void
  }

  class CourseDetailsController {
    -predictionService: PredictionService
    +initData(student: Student, activeSemester: Semester, course: Course, mainContentPane: BorderPane): void
  }

  class CourseRosterController {
    +initData(student: Student, activeSemester: Semester, mainContentPane: BorderPane): void
  }

  class SemestersController {
    +initData(student: Student, onActiveSemesterChanged: Runnable): void
  }

  class SettingsController {
    +initData(student: Student): void
  }

  class WelcomeController
}

package "com.tracker.academictracker.ui.util" {
  class SmoothScrollUtil {
    +applyTo(root: Node): void
    +applyTo(scrollPane: ScrollPane): void
  }
}

package "com.academictracker.prediction2.facade" {
  class PredictionCoreFacade {
    -courseGradeEngine: CourseGradeEngine
    -coursePredictionEngine: CoursePredictionEngine
    -gpaProjectionEngine: GpaProjectionEngine
    -targetGpaEngine: TargetGpaEngine
    +calculateCourseGrade(course: CourseInput): GradeResult
    +predictCourseTarget(course: CourseInput, targetScore: double): CoursePredictionResult
    +projectGpa(transcript: TranscriptInput): GpaProjectionResult
    +calculateRequiredFutureGpa(transcript: TranscriptInput, targetGpa: double): TargetGpaResult
  }
}

package "com.academictracker.prediction2.engine" {
  class CourseGradeEngine {
    +calculateCurrentGrade(course: CourseInput): GradeResult
    +isOfficiallyComplete(course: CourseInput): boolean
  }

  class CoursePredictionEngine {
    +predictTarget(course: CourseInput, targetScore: double): CoursePredictionResult
  }

  class GpaProjectionEngine {
    +project(transcript: TranscriptInput): GpaProjectionResult
  }

  class TargetGpaEngine {
    +calculateRequiredFutureGpa(transcript: TranscriptInput, targetGpa: double): TargetGpaResult
  }
}

package "com.academictracker.prediction2.model" {
  record TranscriptInput
  record SemesterInput
  record CourseInput
  record AssessmentInput
}

package "com.academictracker.prediction2.result" {
  record GradeResult
  record CoursePredictionResult
  record GpaProjectionResult
  record TargetGpaResult
  enum PredictionStatus
}

Launcher --> Main
Main --> DataManager
Main --> DashboardController
Main --> SmoothScrollUtil

Student "1" *-- "0..*" Semester
Semester "1" *-- "0..*" Course
Course "1" *-- "0..*" Assessment
Course --> CourseStatus

DashboardController --> PredictionService
CourseDetailsController --> PredictionService
CourseRosterController --> DataManager
SemestersController --> DataManager
SettingsController --> DataManager
WelcomeController --> DataManager

PredictionService --> PredictionMapper
PredictionService --> PredictionCoreFacade
PredictionMapper --> Student
PredictionMapper --> Semester
PredictionMapper --> Course
PredictionMapper --> Assessment
PredictionMapper --> TranscriptInput
PredictionMapper --> SemesterInput
PredictionMapper --> CourseInput
PredictionMapper --> AssessmentInput

PredictionCoreFacade --> CourseGradeEngine
PredictionCoreFacade --> CoursePredictionEngine
PredictionCoreFacade --> GpaProjectionEngine
PredictionCoreFacade --> TargetGpaEngine

CourseGradeEngine --> GradeResult
CoursePredictionEngine --> CoursePredictionResult
GpaProjectionEngine --> GpaProjectionResult
TargetGpaEngine --> TargetGpaResult

DataManager --> Student
@enduml

