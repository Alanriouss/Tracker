<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-background-color: #f4f7f6;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tracker.academictracker.ui.controller.SemestersController">
    <padding>
        <Insets bottom="40" left="40" right="40" top="40" />
    </padding>

    <!-- THE HEADER ROW -->
    <HBox alignment="CENTER_LEFT">
        <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Semesters" />

        <!-- Region with Hgrow ALWAYS acts as a spring, pushing the button all the way to the right! -->
        <Region HBox.hgrow="ALWAYS" />

        <Button onAction="#handleAddSemester" style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20 10 20; -fx-background-radius: 8; -fx-cursor: hand;" text="+ Add Semester" />
    </HBox>
    <VBox fx:id="addSemesterForm" managed="false" visible="false" spacing="15"
          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5); -fx-border-color: #e5e7eb; -fx-border-radius: 12;">
        <Label text="Add New Semester" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

        <HBox spacing="20">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Year" style="-fx-text-fill: #4b5563; -fx-font-weight: bold;" />
                <TextField fx:id="yearInput" promptText="2026" style="-fx-padding: 10; -fx-background-radius: 6;" />
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Season" style="-fx-text-fill: #4b5563; -fx-font-weight: bold;" />
                <ComboBox fx:id="termInput" maxWidth="Infinity" style="-fx-padding: 5; -fx-background-radius: 6;" />
            </VBox>
        </HBox>

        <HBox spacing="10">
            <Button onAction="#saveNewSemester" text="Add Semester"
                    style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;" />
            <Button onAction="#hideAddForm" text="Cancel"
                    style="-fx-background-color: #f3f4f6; -fx-text-fill: #4b5563; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;" />
        </HBox>
    </VBox>

    <!-- THE SCROLLABLE LIST CONTAINER -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="true" style="-fx-background-color: transparent; -fx-background: #f4f7f6; -fx-border-color: transparent;" styleClass="modern-scroll-pane" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
        <content>
            <!-- This VBox is empty right now. Our Java code will inject the Cards into here! -->
            <VBox fx:id="semesterListContainer" spacing="15" style="-fx-background-color: #f4f7f6;">
                <padding>
                    <Insets bottom="15" right="15" />
                </padding>
            </VBox>
        </content>
    </ScrollPane>

</VBox>
