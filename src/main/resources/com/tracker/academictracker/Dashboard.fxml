<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane styleClass="dashboard-root" stylesheets="@style.css" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tracker.academictracker.ui.controller.DashboardController">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox prefWidth="260.0" spacing="20" style="-fx-background-color: #ffffff; -fx-border-color: #e0e0e0; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets bottom="30" left="20" right="20" top="30" />
            </padding>
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="Academic Tracker" />

            <Button fx:id="btnDashboard" mnemonicParsing="false" onAction="#handleNavigation" style="-fx-background-color: transparent; -fx-text-fill: #1a73e8; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="Dashboard" />
            <Button fx:id="btnSemesters" mnemonicParsing="false" onAction="#handleNavigation" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-font-size: 14px; -fx-cursor: hand;" text="Semesters" />
            <Button fx:id="btnCourseRoster" mnemonicParsing="false" onAction="#handleNavigation" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-font-size: 14px; -fx-cursor: hand;" text=" Course Roster" />
            <Button fx:id="btnSettings" mnemonicParsing="false" onAction="#handleNavigation" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-font-size: 14px; -fx-cursor: hand;" text="Settings" />
        </VBox>
    </left>

    <!-- CENTER AREA -->
    <center>
        <BorderPane fx:id="mainContentPane" style="-fx-background-color: #f8fafc;">
            <!-- TOP HEADER -->
            <top>
                <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ffffff; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
                    <padding>
                        <Insets bottom="20" left="30" right="30" top="20" />
                    </padding>

                    <!-- Nhóm Tên, Badge và ID (Bên trái) -->
                    <VBox spacing="5">
                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <Label fx:id="studentNameLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Student Name" />
                            <Label fx:id="academicStandingLabel" style="-fx-background-color: #d1fae5; -fx-text-fill: #065f46; -fx-padding: 5 15 5 15; -fx-background-radius: 15; -fx-font-weight: bold; -fx-font-size: 13px;" text="Good Standing" />
                        </HBox>
                        <Label fx:id="studentIdLabel" style="-fx-text-fill: #6b7280; -fx-font-size: 14px;" text="ID: N/A" />
                    </VBox>

                    <!-- Lò xo đẩy phần tử sang phải -->
                    <Region HBox.hgrow="ALWAYS" />

                    <!-- Chọn Học Kỳ (Bên phải) -->
                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Label style="-fx-text-fill: #4b5563; -fx-font-size: 14px;" text="Active Semester:" />
                        <ComboBox fx:id="activeSemesterComboBox" style="-fx-background-color: white; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6;" />
                    </HBox>
                </HBox>
            </top>

            <!-- MAIN DASHBOARD CONTENT -->
            <center>
                <ScrollPane fx:id="dashboardScrollPane" fitToWidth="true" hbarPolicy="NEVER" pannable="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" styleClass="modern-scroll-pane" vbarPolicy="AS_NEEDED">
                    <content>
                        <VBox fx:id="dashboardContent" spacing="20" style="-fx-background-color: #f8fafc;">
                            <padding>
                                <Insets bottom="30" left="30" right="30" top="30" />
                            </padding>
                            <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Dashboard Overview" />

                            <!-- HERO CARDS -->
                            <HBox prefHeight="100.0" prefWidth="200.0" spacing="30.0">
                                <children>
                                    <VBox prefHeight="200.0" prefWidth="100.0" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(15,23,42,0.08), 14, 0, 0, 5);" HBox.hgrow="ALWAYS">
                                        <padding>
                                            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                                        </padding>
                                        <children>
                                            <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #64748b;" text="Term GPA" />
                                            <Label fx:id="termGpaLabel" style="-fx-text-fill: #0f172a;" text="N/A">
                                                <font><Font name="System Bold" size="48.0" /></font>
                                            </Label>
                                        </children>
                                    </VBox>
                                    <VBox prefHeight="200.0" prefWidth="100.0" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(15,23,42,0.08), 14, 0, 0, 5);" HBox.hgrow="ALWAYS">
                                        <padding>
                                            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                                        </padding>
                                        <children>
                                            <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #64748b;" text="Overall GPA" />
                                            <Label fx:id="overallGpaLabel" style="-fx-text-fill: #0f172a;" text="N/A">
                                                <font><Font name="System Bold" size="48.0" /></font>
                                            </Label>
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>

                            <!-- PREDICTIVE WIDGET -->
                            <VBox prefHeight="200.0" prefWidth="100.0" style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(15,23,42,0.08), 14, 0, 0, 5);">
                                <children>
                                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2563eb;" text="📈 Overall Predictive Analysis" />
                                    <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="236.0" spacing="15.0">
                                        <children>
                                            <Label style="-fx-text-fill: #334155;" text="Target GPA:"><font><Font size="16.0" /></font></Label>
                                            <TextField fx:id="targetGpaInput" onAction="#calculateTargetGrades" promptText="e.g., 3.5" style="-fx-background-color: #ffffff; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 12 9 12; -fx-text-fill: #0f172a; -fx-prompt-text-fill: #94a3b8;" styleClass="dashboard-target-input" />
                                        </children>
                                    </HBox>
                                    <Label style="-fx-text-fill: #64748b; -fx-padding: 0 0 10 0;" text="Minimum grades required to achieve..." />
                                    <VBox prefHeight="100.0" prefWidth="100.0" style="-fx-background-color: #f1f5f9; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 15;">
                                        <children>
                                            <Label fx:id="predictionResultLabel" style="-fx-text-fill: #334155; -fx-font-size: 14px;" text="Enter a target GPA and press Enter..." wrapText="true" />
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>

                            <!-- ACTIVE COURSES SECTION -->
                            <VBox fx:id="activeCoursesContainer" spacing="20">
                                <padding>
                                    <Insets top="10" />
                                </padding>
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Active Courses" />

                                <VBox alignment="CENTER" prefHeight="120.0" style="-fx-background-color: transparent;">
                                    <children>
                                        <Label style="-fx-text-fill: #6b7280; -fx-font-size: 15px;" text="No courses for this semester. Add courses from the Course Roster." />
                                    </children>
                                </VBox>
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>
        </BorderPane>
    </center>
</BorderPane>
