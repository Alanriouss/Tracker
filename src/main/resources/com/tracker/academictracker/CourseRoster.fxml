<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="true" style="-fx-background-color: transparent; -fx-background: #f8fafc;" styleClass="modern-scroll-pane" stylesheets="@style.css" vbarPolicy="AS_NEEDED" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tracker.academictracker.ui.controller.CourseRosterController">
    <content>
        <VBox spacing="20" style="-fx-background-color: #f8fafc;">
            <padding>
                <Insets bottom="40" left="40" right="40" top="40" />
            </padding>

    <!-- HEADER ROW -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Course Roster" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleAddCourseClick" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;" text="+ Add Course" />
    </HBox>

    <!-- INLINE FORM: ADD NEW COURSE -->
    <VBox fx:id="addCourseForm" managed="false" spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 25; -fx-border-color: #e2e8f0; -fx-border-radius: 12;" visible="false">
        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Add New Course" />

        <!-- Hàng 1: Code & Name -->
        <HBox spacing="20">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill: #475569; -fx-font-size: 13px;" text="Course Code" />
                <TextField fx:id="courseCodeInput" promptText="e.g., CS101" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6;" />
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill: #475569; -fx-font-size: 13px;" text="Course Name" />
                <TextField fx:id="courseNameInput" promptText="e.g., Introduction to Programming" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6;" />
            </VBox>
        </HBox>

        <!-- Hàng 2: Credits & Status -->
        <HBox spacing="20">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill: #475569; -fx-font-size: 13px;" text="Credits" />
                <TextField fx:id="creditsInput" promptText="3" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6;" />
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill: #475569; -fx-font-size: 13px;" text="Status" />
                <ComboBox fx:id="statusInput" maxWidth="Infinity" style="-fx-padding: 6; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-background-color: white;" />
            </VBox>
        </HBox>

        <HBox spacing="10">
            <Button onAction="#saveNewCourse" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;" text="Add Course" />
            <Button onAction="#hideAddForm" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;" text="Cancel" />
        </HBox>
    </VBox>

    <!-- DATA TABLE -->
    <TableView fx:id="courseTable" minHeight="260.0" prefHeight="440.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCode" prefWidth="120.0" style="-fx-font-weight: bold; -fx-alignment: CENTER-LEFT;" text="Course Code" />
            <TableColumn fx:id="colName" prefWidth="250.0" style="-fx-text-fill: #64748b; -fx-alignment: CENTER-LEFT;" text="Course Name" />
            <TableColumn fx:id="colCredits" prefWidth="100.0" style="-fx-alignment: CENTER;" text="Credits" />
            <TableColumn fx:id="colStatus" prefWidth="150.0" style="-fx-alignment: CENTER;" text="Status" />
            <TableColumn fx:id="colGrade" prefWidth="120.0" style="-fx-font-weight: bold; -fx-alignment: CENTER;" text="Current Grade" />
            <TableColumn fx:id="colAction" prefWidth="100.0" style="-fx-alignment: CENTER;" text="Actions" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <!-- Thêm Placeholder (Dòng chữ hiển thị khi bảng trống) -->
        <placeholder>
            <Label text="No courses yet. Click &quot;Add Course&quot; to get started." style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

        </VBox>
    </content>
</ScrollPane>
