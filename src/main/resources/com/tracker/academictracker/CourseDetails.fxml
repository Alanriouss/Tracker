<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="true" style="-fx-background-color: transparent; -fx-background: #f8fafc;" styleClass="modern-scroll-pane" stylesheets="@style.css" vbarPolicy="AS_NEEDED" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tracker.academictracker.ui.controller.CourseDetailsController">
    <content>
        <VBox spacing="20" style="-fx-background-color: #f8fafc;">
            <padding>
                <Insets bottom="40" left="40" right="40" top="40" />
            </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Course Details" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleBackToRoster" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;" text="← Back to Roster" />
    </HBox>

    <HBox spacing="20">
        <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 25; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Course Information" />
            <HBox spacing="40">
                <VBox>
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 13px;" text="Course Code" />
                    <Label fx:id="courseCodeLabel" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #0f172a;" text="N/A" />
                </VBox>
                <VBox>
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 13px;" text="Course Name" />
                    <Label fx:id="courseNameLabel" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #0f172a;" text="N/A" />
                </VBox>
                <VBox>
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 13px;" text="Credits" />
                    <Label fx:id="creditsLabel" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #0f172a;" text="0" />
                </VBox>
                <VBox>
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 13px;" text="Status" />
                    <Label fx:id="statusLabel" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #0284c7;" text="Active" />
                </VBox>
            </HBox>
        </VBox>

        <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 25; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);" prefWidth="250.0">
            <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Grades Overview" />
            <HBox spacing="30" alignment="CENTER_LEFT">
                <VBox>
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 13px;" text="Current Grade" />
                    <Label fx:id="currentGradeLabel" style="-fx-font-weight: bold; -fx-font-size: 36px; -fx-text-fill: #2563eb;" text="N/A" />
                </VBox>
                <VBox>
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 13px;" text="Total Weight" />
                    <Label fx:id="totalWeightLabel" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;" text="0%" />
                </VBox>
            </HBox>
        </VBox>
    </HBox>

    <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #e2e8f0; -fx-border-radius: 12;">
        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Add New Assessment" />
        <HBox spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill: #475569; -fx-font-size: 12px;" text="Assessment Name" />
                <TextField fx:id="assessNameInput" promptText="e.g., Midterm Exam" style="-fx-padding: 9; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6;" />
            </VBox>
            <VBox spacing="5" prefWidth="130.0">
                <Label style="-fx-text-fill: #475569; -fx-font-size: 12px;" text="Category" />
                <ComboBox fx:id="categoryInput" maxWidth="Infinity" style="-fx-padding: 5; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-background-color: white;" />
            </VBox>
            <VBox spacing="5" prefWidth="90.0">
                <Label style="-fx-text-fill: #475569; -fx-font-size: 12px;" text="Weight (%)" />
                <TextField fx:id="weightInput" promptText="20" style="-fx-padding: 9; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6;" />
            </VBox>
            <VBox spacing="5" prefWidth="90.0">
                <Label style="-fx-text-fill: #475569; -fx-font-size: 12px;" text="Max Score" />
                <TextField fx:id="maxScoreInput" promptText="100" style="-fx-padding: 9; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6;" />
            </VBox>
            <VBox spacing="5" prefWidth="90.0">
                <Label style="-fx-text-fill: #475569; -fx-font-size: 12px;" text="Score (Opt.)" />
                <TextField fx:id="scoreInput" promptText="85" style="-fx-padding: 9; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6;" />
            </VBox>
            <VBox alignment="BOTTOM_CENTER">
                <Button onAction="#saveAssessment" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 20; -fx-background-radius: 6; -fx-cursor: hand;" text="Add" />
            </VBox>
        </HBox>
    </VBox>

    <TableView fx:id="assessmentTable" minHeight="220.0" prefHeight="320.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-font-size: 14px;" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colAssessName" prefWidth="250.0" style="-fx-font-weight: bold; -fx-alignment: CENTER-LEFT;" text="Assessment Name" />
            <TableColumn fx:id="colCategory" prefWidth="150.0" style="-fx-alignment: CENTER;" text="Category" />
            <TableColumn fx:id="colWeight" prefWidth="100.0" style="-fx-alignment: CENTER;" text="Weight (%)" />
            <TableColumn fx:id="colScore" prefWidth="120.0" style="-fx-alignment: CENTER; -fx-font-weight: bold;" text="Score" />
            <TableColumn fx:id="colAction" prefWidth="100.0" style="-fx-alignment: CENTER;" text="Action" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <placeholder>
            <Label text="No assessments yet. Add one above to calculate your grade." style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>

    <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">

        <VBox spacing="5" prefWidth="200.0">
            <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="🎯 Target Grade" />
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 12px;" text="Calculate required scores." />
        </VBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="targetCourseGradeInput" onAction="#calculateCourseTarget" promptText="Goal % (e.g., 85)" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-pref-width: 140px;" />
            <Button onAction="#calculateCourseTarget" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 10 20; -fx-cursor: hand;" text="Predict" />
        </HBox>

        <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" style="-fx-background-color: #f8fafc; -fx-padding: 10 15; -fx-background-radius: 6; -fx-border-color: #e2e8f0; -fx-border-radius: 6;">
            <Label fx:id="coursePredictionResultLabel" style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Enter your target grade to see what you need on remaining assignments..." wrapText="true" />
        </VBox>

    </HBox>

        </VBox>
    </content>
</ScrollPane>
