<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tracker.academictracker.ui.controller.WelcomeController">
    <children>
        <VBox alignment="TOP_CENTER" maxWidth="450.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            <children>
                <!-- Logo / Tiêu đề -->
                <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Welcome to Academic Tracker" />
                <Label style="-fx-text-fill: #6b7280; -fx-font-size: 14px;" text="Let's set up your profile to get started." />

                <VBox spacing="15.0">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #374151;" text="Full Name" />
                                <TextField fx:id="nameInput" promptText="e.g., Nguyen Van A" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #d1d5db; -fx-border-radius: 6;" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #374151;" text="Student ID" />
                                <TextField fx:id="idInput" promptText="e.g., SE123456" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #d1d5db; -fx-border-radius: 6;" />
                            </children>
                        </VBox>
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </VBox>

                <Label fx:id="errorLabel" style="-fx-text-fill: #ef4444; -fx-font-size: 12px;" text="" />

                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleCreateProfile" style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 6; -fx-cursor: hand;" text="Create Profile &amp; Continue">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Button>
            </children>
        </VBox>
    </children>
</VBox>